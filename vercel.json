{
  "version": 2,
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ],
  "routes": [
    { "src": "/demo/?$", "dest": "/demo.html" },
    { "src": "/lexia/api/(.*)", "dest": "/api/$1" },
    { "src": "/lexia/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/lexia/?$", "dest": "/index.html" },
    { "src": "/lexia/(.*)", "dest": "/$1" }
  ]
}
