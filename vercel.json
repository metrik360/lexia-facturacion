{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/lexia/api/(.*)",
      "dest": "/api/siigo.js"
    },
    {
      "src": "/lexia/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/lexia/?$",
      "dest": "/index.html"
    },
    {
      "src": "/lexia/(.*)",
      "dest": "/index.html"
    },
    {
      "src": "^/$",
      "status": 302,
      "headers": { "Location": "/lexia" }
    }
  ]
}
