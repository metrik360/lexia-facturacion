{
  "rewrites": [
    {
      "source": "/lexia/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/lexia/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/lexia",
      "destination": "/index.html"
    },
    {
      "source": "/lexia/:path*",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/lexia",
      "permanent": false
    }
  ]
}
